datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum UserRole {
  ADMIN
  WORKER
}

enum DraftVisibility {
  PERSONAL
  SHARED
}

enum SenderType {
  WORKER_PERSONAL
  ADMIN_COMPANY
}

enum RecipientType {
  TO
  CC
}

enum RecipientSourceType {
  SYSTEM
  MANUAL_CC
}

model User {
  id           Int       @id @default(autoincrement())
  name         String
  email        String    @unique
  passwordHash String
  role         UserRole
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  drafts       Draft[]
  mailLogs     MailLog[]
}

model Company {
  id          Int                @id @default(autoincrement())
  name        String
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  emails      CompanyEmail[]
  recipients  MailLogRecipient[]
}

model CompanyEmail {
  id          Int                @id @default(autoincrement())
  companyId   Int
  contactName String?
  email       String
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  company     Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  recipients  MailLogRecipient[]
}

model Draft {
  id          Int              @id @default(autoincrement())
  title       String
  subject     String
  bodyHtml    String           @db.LongText
  visibility  DraftVisibility
  createdById Int
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  createdBy   User             @relation(fields: [createdById], references: [id], onDelete: Cascade)
  attachments DraftAttachment[]
  mailLogs    MailLog[]
}

model DraftAttachment {
  id        Int      @id @default(autoincrement())
  draftId   Int
  fileName  String
  filePath  String
  mimeType  String
  sizeBytes Int
  createdAt DateTime @default(now())

  draft     Draft    @relation(fields: [draftId], references: [id], onDelete: Cascade)
}

model MailLog {
  id              Int        @id @default(autoincrement())
  sentByUserId    Int
  workerName      String
  workerEmail     String
  senderEmail     String
  senderType      SenderType
  draftId         Int?
  subjectSnapshot String     @db.Text
  bodySnapshot    String     @db.LongText
  sentAt          DateTime   @default(now())

  sentByUser      User       @relation(fields: [sentByUserId], references: [id], onDelete: Cascade)
  draft           Draft?     @relation(fields: [draftId], references: [id], onDelete: SetNull)
  recipients      MailLogRecipient[]
}

model MailLogRecipient {
  id              Int                 @id @default(autoincrement())
  mailLogId       Int
  companyId       Int?
  companyEmailId  Int?
  recipientEmail  String
  recipientType   RecipientType
  sourceType      RecipientSourceType

  mailLog         MailLog             @relation(fields: [mailLogId], references: [id], onDelete: Cascade)
  company         Company?            @relation(fields: [companyId], references: [id], onDelete: SetNull)
  companyEmail    CompanyEmail?       @relation(fields: [companyEmailId], references: [id], onDelete: SetNull)
}